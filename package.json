{
  "name": "locker-backend",
  "version": "1.0.0",
  "description": "",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:watch": "vitest",
    "build": "tsup src/server.ts --format esm --target node22 --out-dir dist --clean --sourcemap",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx node_modules/.bin/typeorm migration:run -d src/database/data-source.ts",
    "db:migration:create": "tsx node_modules/.bin/typeorm migration:create",
    "db:migrate:revert": "tsx node_modules/.bin/typeorm migration:revert -d src/database/data-source.ts",
    "db:seed": "tsx src/database/seeders/seed-stations.ts",
    "db:seed:users": "tsx src/database/seeders/seed-users.ts",
    "db:seed:stations": "tsx src/database/seeders/seed-stations.ts",
    "db:seed:packages": "tsx src/database/seeders/seed-packages.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lejiend7/locker-backend.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/lejiend7/locker-backend/issues"
  },
  "homepage": "https://github.com/lejiend7/locker-backend#readme",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.10.0",
    "reflect-metadata": "^0.2.1",
    "typeorm": "^0.3.19"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.11.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
